   "metadata": {},
   "cell_type": "markdown",
   "source": [
    "# Trying the Point-Biserial Correlation Test\n",
    "## Doesn't work as the data isn't normal"
   ],
   "id": "ad381ea9f6b07d53"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-22T14:11:44.368808Z",
     "start_time": "2026-03-22T14:11:44.361361Z"
    }
   },
   "cell_type": "code",
   "source": [
    "#The function to calculate the Point-Biserial Correlation and test\n",
    "def PointBiserial(binary_data, continuous_data):\n",
    "    present = continuous_data[binary_data==1]\n",
    "    absent = continuous_data[binary_data==0]\n",
    "    M1 = present.mean()\n",
    "    M0 = absent.mean()\n",
    "    S = continuous_data.std()\n",
    "    N = len(binary_data)\n",
    "    N1 = len(binary_data[binary_data==1])\n",
    "    N0 = len(binary_data[binary_data==0])\n",
    "    CorrCoef = (M1 - M0)/S * (np.sqrt(N1*N0/(N*(N-1))))\n",
    "    #Check the normality of the data using Shapiro-Wilk test with p=0.05\n",
    "    if shapiro(present).pvalue < 0.05 or shapiro(absent).pvalue < 0.05:\n",
    "        print(\"Warning: Data is not normally distributed. Test invalid.\")\n",
    "        return CorrCoef, None\n",
    "    #H0: CorrCoef = 0\n",
    "    tStat = CorrCoef*np.sqrt((N-2)/(1-CorrCoef**2))\n",
    "    degrees_of_freedom = N - 2\n",
    "    p_value = 2 * t.sf(np.abs(tStat), degrees_of_freedom)\n",
    "    return CorrCoef, p_value"
   ],
   "id": "12b38f16e5e4c50e",
   "outputs": [],
   "execution_count": 44
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-22T14:11:44.390790Z",
     "start_time": "2026-03-22T14:11:44.374037Z"
    }
   },
   "cell_type": "code",
   "source": [
    "#Calculating the Point-Biserial Correlation for each column\n",
    "Columns = [\"distance\",\"avrain\",\"temp_diff\", \"temp_mid\"]\n",
    "Outputs = []\n",
    "for col in Columns:\n",
    "    corr, p_val = PointBiserial(df[\"pres.abs\"], df[col])\n",
    "    if p_val is None:\n",
    "        sig_label = \"Invalid (Not Normal)\"\n",
    "    elif p_val <= 0.05:\n",
    "        sig_label = \"Significant\"\n",
    "    else:\n",
    "        sig_label = \"Not Significant\"\n",
    "    Outputs.append([col, corr, p_val, sig_label])\n",
    "pd.DataFrame(Outputs, columns=['Feature', 'Correlation', 'P-Value', 'Significance'])"
   ],
