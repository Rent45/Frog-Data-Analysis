   "cell_type": "code",
   "source": [
    "#Adding the temperature columns for analysis\n",
    "df[\"temp_diff\"] = df[\"meanmax\"] - df[\"meanmin\"]\n",
    "df[\"temp_mid\"] = (df[\"meanmax\"] + df[\"meanmin\"])/2"
   ],
