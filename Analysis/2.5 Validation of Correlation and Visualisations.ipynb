   "cell_type": "markdown",
   "source": "# Mann-Whitney U-test",
   "id": "934614f31bf09d3f"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-22T14:11:45.127664Z",
     "start_time": "2026-03-22T14:11:45.121946Z"
    }
   },
   "cell_type": "code",
   "source": [
    "#Defining the U-test function\n",
    "def Utest(binary_data, continuous_data):\n",
    "    Ranking = continuous_data.rank()\n",
    "    R1 = Ranking[binary_data==1].sum()\n",
    "    R0 = Ranking[binary_data==0].sum()\n",
    "    N1 = len(Ranking[binary_data==1])\n",
    "    N0 = len(Ranking[binary_data==0])\n",
    "    U1 = N1*N0+N1*(N1+1)/2 - R1\n",
    "    U0 = N0*N1+N0*(N0+1)/2 - R0\n",
    "    U = min(U1, U0)\n",
    "    #We will use the z-test for the p-value\n",
    "    Umean = (N1*N0)/2\n",
    "    Usd = np.sqrt(N1*N0*(N1+N0+1)/12)\n",
    "    Z = (U-Umean)/Usd\n",
    "    p_value = 2 * norm.sf(np.abs(Z))\n",
    "    return U, p_value"
   ],
   "id": "3104bd890dc011e",
   "outputs": [],
   "execution_count": 48
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-03-22T14:11:45.154575Z",
     "start_time": "2026-03-22T14:11:45.139229Z"
    }
   },
   "cell_type": "code",
   "source": [
    "#Calculating the Mann-Whitney U-test for each column\n",
    "Columns = [\"distance\",\"avrain\",\"temp_diff\", \"temp_mid\"]\n",
    "Outputs = []\n",
    "for col in Columns:\n",
    "    u, p_val = Utest(df[\"pres.abs\"], df[col])\n",
    "    if p_val <= 0.05:\n",
    "        sig_label = \"Significant\"\n",
    "    else:\n",
    "        sig_label = \"Not Significant\"\n",
    "    Outputs.append([col, u, p_val, sig_label])\n",
    "pd.DataFrame(Outputs, columns=['Feature', 'Value of U', 'P-Value', 'Significance'])"
   ],
